# Site origin — used by metadataBase, OG image, sitemap, hreflang
NEXT_PUBLIC_SITE_URL=https://kazkioti.kz

# Email delivery (Resend) — required in production for /api/lead
# When unset in dev, the lead route logs to console and still returns 200
RESEND_API_KEY=re_xxx
RESEND_FROM=site@kazkioti.kz
RESEND_TO=info@kazkioti.kz

# Rate-limit (Vercel KV / Upstash Redis) — optional
# When unset, /api/lead skips rate-limiting (safe for dev and first deploy)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Messenger deep-links (FAB and contacts page)
WHATSAPP_NUMBER=77478764444
TELEGRAM_USERNAME=kazkioti
