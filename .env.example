# Site origin — used by metadataBase, OG image, sitemap, hreflang
NEXT_PUBLIC_SITE_URL=https://kazkioti.kz

# Email delivery (Resend) — optional channel for /api/lead
# When unset, leads still go to Bitrix if BITRIX_WEBHOOK_URL is set
RESEND_API_KEY=re_xxx
RESEND_FROM=site@kazkioti.kz
RESEND_TO=info@kazkioti.kz

# Bitrix24 incoming webhook — creates a Lead via crm.lead.add
# Format: https://<portal>.bitrix24.kz/rest/<user_id>/<token>/
# Create at: CRM → Разработчикам → Другое → Входящий вебхук (scope: crm)
BITRIX_WEBHOOK_URL=

# Rate-limit (Vercel KV / Upstash Redis) — optional
# When unset, /api/lead skips rate-limiting (safe for dev and first deploy)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Messenger deep-links (FAB and contacts page)
WHATSAPP_NUMBER=77478764444
TELEGRAM_USERNAME=kazkioti

# Social channels (footer icons) — broadcast only, not for contact
INSTAGRAM_URL=https://instagram.com/kazkioti
YOUTUBE_URL=https://youtube.com/@kazkioti
TELEGRAM_CHANNEL_URL=https://t.me/kazkioti

# Analytics (optional) — when unset, the tracker is not rendered
NEXT_PUBLIC_YANDEX_METRICA_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Search engine verification (optional) — meta tags omitted when unset
GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=
